# Copy to .env for local dev. Railway sets these in the service's Variables tab.
# Never commit a real .env.

# Railway provides this once you add a PostgreSQL plugin to the project.
# There is no automatic DATABASE_URL without the plugin.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/planner_sync

# Only needed when connecting to Postgres over the public internet.
# Railway's private network does not need it.
DATABASE_SSL=false

# Produced by `npm run hash`. This is a hash, not your passphrase — it is safe
# to paste into Railway, and cannot be turned back into the passphrase.
# Without it, /auth returns 503 and nothing can sync.
PASSPHRASE_HASH=

# Comma separated. No wildcard. If this is empty, no browser can call the API.
ALLOWED_ORIGINS=https://angela3famuz.github.io

# Railway injects PORT. Locally it defaults to 8080.
PORT=8080
